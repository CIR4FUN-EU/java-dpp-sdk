  "info": {
    "_postman_id": "911cc53d-9d2e-4458-b58b-f721da522049",
    "name": "DPP Lifecycle API",
    "description": "Manual smoke collection for the mock DPP repository lifecycle API. Run requests in order. CreateDPP generates a fresh dppId/productId and captures versionDate. HEAD /dpps/{dppId} is an internal lightweight verification endpoint used by the registry. Lifecycle events are internal mock events, not full Track & Trace.",
